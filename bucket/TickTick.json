{
    "version": "8.0.5.0",
    "description": "(Chinese version) A Todo list, checklist and task manager app.",
    "homepage": "https://dida365.com/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://dida365.com/tos"
    },
    "architecture": {
        "64bit": {
            "url": "https://cdn.dida365.cn/download/win64/dida_win_setup_release_x64_8050.exe",
            "hash": "31eaec949a0c0ef4b4aaebfc92f271fcf8b6cbc8b6268df3048ad5b72e129eaf"
        },
        "32bit": {
            "url": "https://cdn.dida365.cn/download/win/dida_win_setup_release_x86_8050.exe",
            "hash": "c197001a3c896d1c4c8e1e41aaec5c362ad0853ea54a21d0df4917300ce91fd1"
        }
    },
    "innosetup": true,
    "shortcuts": [
        [
            "TickTick.exe",
            "滴答清单"
        ]
    ],
    "pre_install": [
        "Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name air) scripts/AirUtils.psm1)",
        "RedirectDirectory \"$env:APPDATA\\Tick_Tick\" \"$persist_dir\\APPDATA\\Tick_Tick\"",
        "Remove-Module -Name AirUtils"
    ],
    "uninstaller": {
        "script": [
            "if ($cmd -eq 'uninstall') {",
            "    Import-Module $(Join-Path $(Find-BucketDirectory -Root -Name air) scripts/AirUtils.psm1)",
            "    RemoveJunction \"$env:APPDATA\\Tick_Tick\"",
            "    Remove-Module -Name AirUtils",
            "}"
        ]
    },
    "checkver": {
        "url": "https://pull.dida365.com/windows/release_note.json",
        "jsonpath": "$.version"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://cdn.dida365.cn/download/win64/dida_win_setup_release_x64_$cleanVersion.exe"
            },
            "32bit": {
                "url": "https://cdn.dida365.cn/download/win/dida_win_setup_release_x86_$cleanVersion.exe"
            }
        }
    }
}
